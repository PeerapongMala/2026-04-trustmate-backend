# ============================================
# TrustMate Backend — Environment Variables
# ============================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.

# --- Database (Neon PostgreSQL, Singapore) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- JWT (REQUIRED — startup will fail without this) ---
# Generate with: openssl rand -base64 64
JWT_SECRET="your-long-random-secret-at-least-32-chars"

# --- Google OAuth ---
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxxxx"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# --- Frontend URL (for OAuth redirect + reset password links) ---
FRONTEND_URL="http://localhost:3000"

# --- Mistral AI (chatbot "เมท" + post moderation) ---
MISTRAL_API_KEY="xxxxx"

# --- Resend (password reset emails) ---
RESEND_API_KEY="re_xxxxx"

# --- Server ---
PORT=4000
